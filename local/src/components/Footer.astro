    <ModalSuccess id="modal-success-footer" />
</footer>
<script>
    import { gsap } from "gsap";

    const initRipples = () => {
        const spheres = document.querySelectorAll(".sphere");

        spheres.forEach((sphereContainer) => {
            // предотвращаем повторную инициализацию при astro:page-load
            if (sphereContainer instanceof HTMLElement) {
                if (sphereContainer.dataset.ripplesInit === "1") return;
                sphereContainer.dataset.ripplesInit = "1";
            }

            const btn = sphereContainer.querySelector(".sphere__btn");
            if (!btn) return;

            // Получаем вариант из data-атрибута, по умолчанию "1"
            const variant = sphereContainer.dataset.variant || "1";

            // Настройки эффекта общие для всех вариантов
            const CONFIG = {
                waveCount: 3, // Сколько волн за 1 клик
                staggerDelay: 0.13, // Задержка между волнами
                baseDuration: 1.05, // Базовое время жизни волны
                maxScale: 3.2, // Во сколько раз увеличивается (относительно размера волны)
            };

            const spawn = (e?: PointerEvent | MouseEvent | KeyboardEvent) => {
                // микро-"удар" по кнопке — добавляет ощущение физики
                gsap.fromTo(
                    btn,
                    { scale: 1 },
                    {
                        scale: 0.97,
                        duration: 0.11,
                        yoyo: true,
                        repeat: 1,
                        ease: "power2.inOut",
                        overwrite: true,
                    },
                );

                const rect = sphereContainer.getBoundingClientRect();
                const isPointEvent =
                    !!e &&
                    ("clientX" in e || (e instanceof MouseEvent) || (e instanceof PointerEvent));

                const origin = isPointEvent
                    ? {
                          x: (e as MouseEvent).clientX - rect.left,
                          y: (e as MouseEvent).clientY - rect.top,
                      }
                    : { x: rect.width / 2, y: rect.height / 2 };

                for (let i = 0; i < CONFIG.waveCount; i++) {
                    // рисуем волны в контейнере, чтобы их не обрезал overflow кнопки
                    createRipple(sphereContainer, i, variant, CONFIG, origin);
                }
            };

            // pointerdown ощущается "живее", чем click
            btn.addEventListener("pointerdown", (e) => spawn(e), { passive: true });
            // доступность: клавиатура (Enter/Space)
            btn.addEventListener("keydown", (e) => {
                if (e.key === "Enter" || e.key === " ") spawn(e);
            });
        });

        function createRipple(
            container: Element,
            index: number,
            variant: string,
            config: {
                waveCount: number;
                staggerDelay: number;
                baseDuration: number;
                maxScale: number;
            },
            origin: { x: number; y: number },
        ) {
            const ripple = document.createElement("div");
            ripple.classList.add("ripple-wave");
            // Добавляем класс, специфичный для варианта
            ripple.classList.add(`ripple-wave--v${variant}`);

            // геометрия: волна рождается в точке клика, а не из центра
            const rect = container.getBoundingClientRect();
            const maxSide = Math.max(rect.width, rect.height);
            const baseSize = maxSide * (0.42 + index * 0.04);
            ripple.style.setProperty("--ripple-x", `${origin.x}px`);
            ripple.style.setProperty("--ripple-y", `${origin.y}px`);
            ripple.style.setProperty("--ripple-size", `${baseSize}px`);
            container.appendChild(ripple);

            const endScale = config.maxScale + index * 0.25 + gsap.utils.random(-0.08, 0.14);
            const dur = config.baseDuration + index * 0.14;

            gsap.fromTo(
                ripple,
                { scale: 0.35, opacity: 0 },
                {
                    scale: endScale,
                    opacity: 0,
                    duration: dur,
                    delay: index * config.staggerDelay,
                    ease: "power3.out",
                    keyframes: [
                        { opacity: 1, duration: dur * 0.14, ease: "power2.out" },
                        { opacity: 0.55, duration: dur * 0.28, ease: "none" },
                        { opacity: 0, duration: dur * 0.5, ease: "power2.in" },
                    ],
                    onComplete: () => ripple.remove(),
                },
            );
        }
    };

    // Запускаем
    initRipples();

    // Если в Astro используется View Transitions (router), нужно переинициализировать скрипт
    document.addEventListener("astro:page-load", initRipples);

    // Логика подписки
    import MicroModal from "micromodal";

    const initSubscribe = () => {
        const subscribeForm = document.querySelector(
            ".subscribe__form",
        ) as HTMLFormElement;
        if (subscribeForm) {
            subscribeForm.addEventListener("submit", (e) => {
                e.preventDefault();
                if (subscribeForm.checkValidity()) {
                    MicroModal.show("modal-success-footer");
                    subscribeForm.reset();
                }
            });
        }
    };

    initSubscribe();
    document.addEventListener("astro:page-load", initSubscribe);
</script>
